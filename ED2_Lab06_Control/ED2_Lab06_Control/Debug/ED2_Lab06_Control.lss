// --- Implementación de UART con Modo Doble Velocidad ---
void UART_Init(uint32_t baud)
{
	// ACTIVAR U2X0: Reduce el error de baud rate de 8.5% a 2.1% para 115200
	UCSR0A |= (1 << U2X0);
